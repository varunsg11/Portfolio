# Copy to .env and fill in. Never commit .env (it's gitignored).

# ── Email (Resend) ──
RESEND_API_KEY=your_resend_api_key_here
CONTACT_TO_EMAIL=varunsg118@gmail.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

# ── Database (Neon Postgres + pgvector) ──
# From the Neon dashboard connection string. The app auto-rewrites the
# postgresql:// prefix to postgresql+psycopg:// for you.
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# ── OpenAI (RAG chatbot) ──
OPENAI_API_KEY=sk-your_openai_key_here
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# ── Analytics (optional) ──
# If set, GET /api/analytics requires: Authorization: Bearer <value>
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ANALYTICS_KEY=
